APP_NAME="Power Roster"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_DATABASE=database/database.sqlite

# Production : utiliser PostgreSQL (backups via `php artisan backup:run` = pg_dump).
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=power_roster
# DB_USERNAME=power_roster
# DB_PASSWORD=

# Backups (voir config/backup.php) — planifié tous les jours à 03:00
# BACKUP_KEEP=7
# BACKUP_DESTINATION=

SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=file

BROADCAST_CONNECTION=null

# Reverb (temps réel messagerie) — laisser vide pour activer le polling 60s côté client
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# Mail — utiliser "log" en dev (les e-mails apparaissent dans storage/logs/laravel.log)
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@trackcoach.dev"
MAIL_FROM_NAME="${APP_NAME}"

# File d'attente. En dev : "sync" (aucun worker requis, e-mails envoyés dans la requête).
# En prod : "database" (ou "redis") + lancer `php artisan queue:work` pour traiter les jobs en arrière-plan.
QUEUE_CONNECTION=sync

# Stockage vidéos feedback — upload multipart local tant que les clés R2 sont absentes
FILESYSTEM_DISK=local
# Cloudflare R2 (compatible S3) : dès que ces variables sont renseignées, l’app active l’upload direct
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=auto
# AWS_BUCKET=track-coach-videos
# AWS_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# AWS_URL=
# AWS_USE_PATH_STYLE_ENDPOINT=true
# Sur le bucket R2 : CORS Allow Origins = ton domaine Render + http://127.0.0.1:8000
# Methods = PUT, GET, HEAD ; Headers = Content-Type, *

# Premier coach : php artisan coach:invite coach@example.com --name="Jean Dupont"

VITE_REVERB_APP_KEY=
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http

# PostHog (product analytics + session replay) — laisser vide pour désactiver
# Créer un projet sur https://eu.posthog.com et coller la Project API Key
# IMPORTANT (Render / Docker) : utiliser POSTHOG_KEY (runtime), PAS seulement VITE_*.
# Les VITE_* ne sont injectées qu'au `npm run build` — souvent absentes du build Docker.
POSTHOG_KEY=
POSTHOG_HOST=https://eu.i.posthog.com
POSTHOG_UI_HOST=https://eu.posthog.com
# Optionnel : fallback build Vite en local
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# APK Android athlète (Capacitor) — URL HTTPS de production chargée par la WebView
# Exemple : https://app.trackcoach.fr
CAPACITOR_SERVER_URL=
